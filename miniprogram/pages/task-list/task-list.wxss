.list {
  padding: 16rpx;
}

.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-top {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-mid {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-line {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}

.card-bot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-count {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: bold;
}

.card-actions {
  display: flex;
  gap: 32rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #1989fa;
}

.fab {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #1989fa;
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  white-space: nowrap;
  box-shadow: 0 8rpx 24rpx rgba(25,137,250,0.4);
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
