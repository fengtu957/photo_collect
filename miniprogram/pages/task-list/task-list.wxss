.list {
  padding: 16rpx;
}

.notice-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #eef6ff 0%, #dbeeff 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(25, 137, 250, 0.12);
}

.notice-copy {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  font-size: 34rpx;
  color: #1457a8;
  font-weight: bold;
  margin-bottom: 14rpx;
}

.notice-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.notice-item {
  width: 50%;
  padding: 0 8rpx;
  box-sizing: border-box;
  margin-bottom: 10rpx;
}

.notice-tip {
  display: block;
  font-size: 24rpx;
  color: #2b6cb8;
  line-height: 1.6;
  word-break: break-all;
  overflow-wrap: break-word;
}

.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-top {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.title-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
}

.title-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #28b446;
  box-sizing: border-box;
  margin-right: 16rpx;
  position: relative;
  flex-shrink: 0;
}

.title-icon-head {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #28b446;
}

.title-icon-body {
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  transform: translateX(-50%);
  width: 18rpx;
  height: 10rpx;
  border-radius: 10rpx 10rpx 8rpx 8rpx;
  background: #28b446;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-mid {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-info {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.card-line {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 2;
  word-break: break-all;
  overflow-wrap: break-word;
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.card-bot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-count {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: bold;
}

.card-actions {
  display: flex;
  gap: 32rpx;
  align-items: center;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-icon {
  font-size: 34rpx;
  line-height: 1;
}

.action-icon-list {
  color: #2d8cf0;
}

.action-icon-camera {
  color: #999;
}

.btn-text {
  font-size: 28rpx;
  color: #1989fa;
}

.floating-actions {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.scan-fab {
  background: white;
  color: #1989fa;
  padding: 24rpx 40rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  white-space: nowrap;
  border: 1rpx solid #d6e8ff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.fab {
  background: #1989fa;
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  white-space: nowrap;
  box-shadow: 0 8rpx 24rpx rgba(25,137,250,0.4);
  flex-shrink: 0;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
