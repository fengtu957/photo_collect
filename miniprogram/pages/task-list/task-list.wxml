<scroll-view scroll-y style="height: 100vh;">
  <view class="list">
    <view class="notice-banner">
      <view class="notice-copy">
        <text class="notice-title">使用说明</text>
        <view class="notice-grid">
          <view class="notice-item">
            <text class="notice-tip">· {{createTip}}</text>
          </view>
          <view class="notice-item">
            <text class="notice-tip">· {{submissionTip}}</text>
          </view>
          <view class="notice-item">
            <text class="notice-tip">· {{durationTip}}</text>
          </view>
          <view class="notice-item">
            <text class="notice-tip">· {{retentionTip}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="toolbar-card">
      <view class="filter-list">
        <view
          class="filter-chip {{activeFilter === item ? 'filter-chip-active' : ''}}"
          wx:for="{{filterOptions}}"
          wx:key="*this"
          data-value="{{item}}"
          bindtap="onFilterChange"
        >
          {{item}}
        </view>
      </view>
      <input
        class="search-input"
        placeholder="搜索任务标题 / 任务码"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        adjust-position="{{false}}"
      />
    </view>
    <view class="card" wx:for="{{tasks}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="card-top">
        <view class="title-wrap">
          <view class="title-icon">
            <view class="title-icon-head"></view>
            <view class="title-icon-body"></view>
          </view>
          <text class="card-title">{{item.title}}</text>
        </view>
      </view>
      <view class="card-mid">
        <view class="card-info">
          <text class="card-line">任务码：{{item.task_code || '自动生成中'}}</text>
          <text class="card-line">规格：{{item.spec_text}}</text>
          <text class="card-line">创建日期：{{item.created_at_formatted}}</text>
          <text class="card-line">截止日期：{{item.end_time_formatted}}</text>
        </view>
        <image class="status-icon" src="{{item.status.icon}}" mode="aspectFit" />
      </view>
      <view class="card-bot">
        <text class="card-count">已收集 {{item.stats.total_submissions || 0}} 张</text>
        <view class="card-actions">
          <view class="action-item" catchtap="viewList" data-id="{{item.id}}">
            <text class="action-icon action-icon-list">▣</text>
            <text class="btn-text">照片列表</text>
          </view>
          <view class="action-item" catchtap="goToUpload" data-id="{{item.id}}">
            <text class="action-icon action-icon-camera">▣</text>
            <text class="btn-text">拍照</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{tasks.length === 0}}">{{emptyText}}</view>
  </view>
  <view style="height: 120rpx;"></view>
</scroll-view>

<view class="join-overlay" wx:if="{{showJoinActions}}" bindtap="closeJoinActions"></view>

<view class="join-code-modal" wx:if="{{showJoinActions && showTaskCodePanel}}" catchtap="noop">
  <view class="join-code-title">任务码加入采集</view>
  <input
    class="join-code-input"
    type="number"
    maxlength="5"
    placeholder="输入5位任务码"
    value="{{joinTaskCode}}"
    bindinput="onJoinTaskCodeInput"
    adjust-position="{{false}}"
  />
  <text class="join-code-tip">输入任务码后可直接进入对应采集任务。</text>
  <view class="join-code-actions">
    <view class="join-code-cancel" bindtap="closeJoinActions">取消</view>
    <view class="join-code-submit {{joiningByCode ? 'join-code-submit-disabled' : ''}}" bindtap="joinTaskByCode">
      {{joiningByCode ? '加入中...' : '确认加入'}}
    </view>
  </view>
</view>

<view class="floating-actions">
  <view class="join-floating">
    <view class="join-actions-panel" wx:if="{{showJoinActions && !showTaskCodePanel}}" catchtap="noop">
      <view class="join-action-item" bindtap="scanTaskFromJoin">扫一扫</view>
      <view class="join-action-item" bindtap="openTaskCodePanel">任务码</view>
    </view>
    <view class="scan-fab" bindtap="toggleJoinActions">加入任务</view>
  </view>
  <view class="fab" bindtap="goToCreate">+ 创建任务</view>
</view>
