/* 页面容器 */
.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  word-break: break-all;
  overflow-wrap: break-word;
  flex: 1;
}

.task-edit-link {
  font-size: 28rpx;
  color: #1989fa;
  flex-shrink: 0;
  line-height: 1.6;
}

.card-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 分隔线 */
.divider {
  border-bottom: 1rpx solid #f5f5f5;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-row .label {
  color: #999;
  min-width: 160rpx;
}

.info-row .value {
  color: #333;
  flex: 1;
  word-break: break-all;
  overflow-wrap: break-word;
}

.status-text {
  color: #ff9500;
}

.export-panel {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.export-panel-tip {
  padding-bottom: 4rpx;
}

.export-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.export-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.export-locked-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.export-textarea {
  display: block;
  width: 100%;
  height: 320rpx;
  font-size: 30rpx;
  color: #333;
  border: 1rpx solid #d6e8ff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8fbff;
  line-height: 1.6;
}

.export-textarea::placeholder {
  color: #999;
}

.export-tip {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-top: 12rpx;
}

.export-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.export-action-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  text-align: center;
}

.export-action-primary {
  background: #1989fa;
  color: #fff;
}

.export-action-secondary {
  background: #eef5ff;
  color: #1989fa;
  border: 1rpx solid #d6e8ff;
}

.export-result {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #d6e8ff;
}

.export-result-line {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
}

.export-result-error {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ff4444;
  line-height: 1.6;
}

.export-link-box {
  display: block;
  width: 100%;
  height: 260rpx;
  margin-top: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1rpx solid #d6e8ff;
  background: #fff;
  overflow: hidden;
}

.export-link-text {
  display: block;
  color: #1989fa;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-all;
  overflow-wrap: break-word;
}

.entry-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8f1ff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.entry-title {
  display: block;
  font-size: 28rpx;
  color: #1989fa;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.qr-canvas {
  position: fixed;
  left: -2000px;
  top: -2000px;
  width: 360px;
  height: 360px;
}

/* 章节标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 空状态 */
.empty {
  background: white;
  border-radius: 12rpx;
  padding: 80rpx 24rpx;
  text-align: center;
  border: 1rpx solid #eee;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 提交卡片 */
.submission-card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.submission-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.edit-link {
  font-size: 28rpx;
  color: #1989fa;
  padding: 8rpx 16rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.status-submitted {
  background: #e8f4ff;
  color: #1989fa;
}

.status-rejected {
  background: #ffe8e8;
  color: #ff4444;
}

.status-draft {
  background: #f5f5f5;
  color: #999;
}

/* AI评估 */
.ai-evaluation {
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.score-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.score-label {
  font-size: 28rpx;
  color: #666;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1989fa;
  margin-left: 8rpx;
}

.breakdown {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.breakdown-item {
  flex: 0 0 calc(33.333% - 8rpx);
  background: white;
  border-radius: 6rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.breakdown-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.breakdown-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.issues, .suggestions {
  margin-top: 12rpx;
}

.issues-title, .suggestions-title {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.issue-item, .suggestion-item {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
  line-height: 1.5;
}

.ai-pending {
  font-size: 26rpx;
  color: #ff9500;
}

.ai-error {
  font-size: 26rpx;
  color: #ff4444;
}

/* 自定义数据 */
.custom-data {
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}

.custom-item {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.custom-label {
  color: #999;
  min-width: 120rpx;
}

.custom-value {
  color: #333;
  flex: 1;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #1989fa;
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(25,137,250,0.4);
}

/* 创建者底栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background: white;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
}

.btn-danger {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  background: #fff0f0;
  color: #ff4444;
  border: 1rpx solid #ffcccc;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  background: #1989fa;
  color: white;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  background: #eef5ff;
  color: #1989fa;
  border: 1rpx solid #d6e8ff;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}
