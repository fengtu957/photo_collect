<view class="page">
  <!-- 任务信息卡片 -->
  <view class="card" wx:if="{{task}}">
    <view class="card-header">
      <view class="card-title">{{task.title}}</view>
      <text class="task-edit-link" wx:if="{{isCreator}}" catchtap="editTask">编辑</text>
    </view>
    <view class="card-desc" wx:if="{{task.description}}">{{task.description}}</view>

    <view class="divider"></view>

    <view class="info-row">
      <text class="label">照片规格：</text>
      <text class="value">{{task.photo_spec.name}} ({{task.photo_spec.width}}×{{task.photo_spec.height}})</text>
    </view>

    <view class="info-row" wx:if="{{task.photo_spec.background_color}}">
      <text class="label">背景色要求：</text>
      <text class="value">{{task.photo_spec.background_color}}</text>
    </view>

    <view class="info-row" wx:if="{{task.photo_spec.max_size_kb > 0}}">
      <text class="label">大小限制：</text>
      <text class="value">{{task.photo_spec.max_size_kb}}K，超出自动压缩</text>
    </view>

    <view class="info-row">
      <text class="label">AI分析：</text>
      <text class="value">{{aiAnalysisEnabled ? '已开启' : '已关闭'}}</text>
    </view>

    <view class="info-row">
      <text class="label">开始时间：</text>
      <text class="value">{{startTime}}</text>
    </view>

    <view class="info-row">
      <text class="label">截止时间：</text>
      <text class="value">{{endTime}}</text>
    </view>

    <view class="info-row" wx:if="{{taskStatusText}}">
      <text class="label">当前状态：</text>
      <text class="value status-text">{{taskStatusText}}</text>
    </view>

    <view class="info-row" wx:if="{{task.custom_fields && task.custom_fields.length > 0}}">
      <text class="label">采集字段：</text>
      <text class="value">{{customFieldSummary}}</text>
    </view>

    <view class="export-panel export-panel-tip" wx:if="{{isCreator && !canExportTask}}">
      <text class="export-title">导出图片</text>
      <text class="export-locked-tip">活动结束后才能导出图片</text>
    </view>

    <view class="export-panel" wx:elif="{{isCreator && canExportTask}}">
      <text class="export-title">导出图片</text>
      <text class="export-label">文件命名模板</text>
      <textarea
        class="export-textarea"
        value="{{exportTemplate}}"
        placeholder="请输入图片命名模板，不要写扩展名"
        bindinput="onExportTemplateInput"
        adjust-position="{{false}}"
        maxlength="-1"
      ></textarea>
      <text class="export-tip">{{exportTemplateHint}}</text>

      <view class="export-actions">
        <view class="export-action-btn export-action-primary" bindtap="exportTask">开始导出</view>
        <view class="export-action-btn export-action-secondary" bindtap="refreshExportStatus" wx:if="{{exportFileName && exportStatus !== 'success'}}">刷新导出状态</view>
        <view class="export-action-btn export-action-secondary" bindtap="authorizeTaskExport" wx:if="{{exportFileName && exportStatus === 'success'}}">重新授权链接</view>
        <view class="export-action-btn export-action-secondary" bindtap="copyExportLink" wx:if="{{exportDownloadUrl && exportStatus === 'success'}}">复制链接</view>
      </view>

      <view class="export-result" wx:if="{{exportFileName}}">
        <text class="export-result-line" wx:if="{{exportStatusText}}">导出状态：{{exportStatusText}}</text>
        <text class="export-result-line">导出文件：{{exportFileName}}</text>
        <text class="export-result-line">图片数量：{{exportCount}}</text>
        <text class="export-result-line" wx:if="{{exportExpiresAt}}">链接有效期至：{{exportExpiresAt}}</text>
        <text class="export-result-error" wx:if="{{exportErrorMessage}}">{{exportErrorMessage}}</text>
        <text class="export-label">下载链接</text>
        <view class="export-link-box">
          <text class="export-link-text">{{exportDownloadUrl || '导出完成后这里会出现下载链接'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="entry-card" wx:if="{{!isCreator && fromShare}}">
    <text class="entry-title">你是通过二维码进入的参与者页面</text>
    <text class="entry-desc">先确认照片规格和采集字段，再点击下方上传照片。</text>
  </view>

  <!-- 提交列表 -->
  <view class="section-header">
    <text class="section-title">{{isCreator ? '提交记录' : '我的提交'}}</text>
    <text class="section-count">({{total}})</text>
  </view>

  <view class="empty" wx:if="{{submissions.length === 0}}">
    <text class="empty-text">{{isCreator ? '暂无提交记录' : '你还没有提交，点击下方上传照片'}}</text>
  </view>

  <view class="submission-card" wx:for="{{submissions}}" wx:key="id">
    <view class="submission-header">
      <image class="avatar" src="{{item.user_info.avatar_url}}" mode="aspectFill" />
      <view class="user-info">
        <text class="nickname">{{item.user_info.nick_name}}</text>
        <text class="time">{{item.createdAtFormatted}}</text>
      </view>
      <view class="submission-actions">
        <text class="edit-link" catchtap="editSubmission" data-id="{{item.id}}" wx:if="{{isCreator || item.user_id === currentUserId}}">
          编辑
        </text>
        <text class="delete-link" catchtap="deleteSubmissionRecord" data-id="{{item.id}}" wx:if="{{isCreator}}">
          删除
        </text>
      </view>
    </view>

    <view class="ai-evaluation" wx:if="{{aiAnalysisEnabled && item.ai_evaluation && item.ai_evaluation.status === 'success'}}">
      <view class="score-row">
        <text class="score-label">AI评分：</text>
        <text class="score-value">{{item.ai_evaluation.score}}</text>
      </view>

      <view class="breakdown" wx:if="{{item.ai_evaluation.breakdown}}">
        <view class="breakdown-item">
          <text class="breakdown-label">清晰度</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.clarity}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">光线</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.lighting}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">角度</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.angle}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">背景</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.background}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">表情</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.expression}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">构图</text>
          <text class="breakdown-value">{{item.ai_evaluation.breakdown.composition}}</text>
        </view>
      </view>

      <view class="issues" wx:if="{{item.ai_evaluation.issues && item.ai_evaluation.issues.length > 0}}">
        <text class="issues-title">问题：</text>
        <text class="issue-item" wx:for="{{item.ai_evaluation.issues}}" wx:key="*this" wx:for-item="issue">• {{issue}}</text>
      </view>

      <view class="suggestions" wx:if="{{item.ai_evaluation.suggestions && item.ai_evaluation.suggestions.length > 0}}">
        <text class="suggestions-title">建议：</text>
        <text class="suggestion-item" wx:for="{{item.ai_evaluation.suggestions}}" wx:key="*this" wx:for-item="suggestion">• {{suggestion}}</text>
      </view>
    </view>

    <view class="ai-evaluation" wx:if="{{aiAnalysisEnabled && item.ai_evaluation && item.ai_evaluation.status === 'pending'}}">
      <text class="ai-pending">AI评估中...</text>
    </view>

    <view class="ai-evaluation" wx:if="{{aiAnalysisEnabled && item.ai_evaluation && item.ai_evaluation.status === 'failed'}}">
      <text class="ai-error">AI评估失败：{{item.ai_evaluation.error}}</text>
    </view>

    <view class="custom-data" wx:if="{{item.customDataList && item.customDataList.length > 0}}">
      <view class="custom-item" wx:for="{{item.customDataList}}" wx:key="label" wx:for-item="field">
        <text class="custom-label">{{field.label}}：</text>
        <text class="custom-value">{{field.value}}</text>
      </view>
    </view>
  </view>

  <!-- 分页状态 -->
  <view class="load-more" wx:if="{{loadingMore}}">
    <text class="load-more-text">加载中...</text>
  </view>
  <view class="load-more" wx:elif="{{!hasMore && submissions.length > 0}}">
    <text class="load-more-text">已加载全部</text>
  </view>

  <!-- 创建者：双按钮底栏 -->
  <view class="footer" wx:if="{{isCreator}}">
    <view class="btn-danger" bindtap="deleteActivity">删除活动</view>
    <view class="btn-secondary" bindtap="saveTaskQr">保存二维码</view>
    <view class="btn-primary" bindtap="goToUpload">上传照片</view>
  </view>

  <!-- 非创建者：双按钮底栏 -->
  <view class="footer" wx:else>
    <view class="btn-secondary" bindtap="saveTaskQr">保存二维码</view>
    <view class="btn-primary" bindtap="goToUpload">
      <text>{{mySubmissionId ? '编辑提交' : '上传照片'}}</text>
    </view>
  </view>

  <canvas canvas-id="taskQrCanvas" class="qr-canvas"></canvas>
</view>
