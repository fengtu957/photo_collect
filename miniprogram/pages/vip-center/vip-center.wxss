.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.hero-card {
  background: linear-gradient(135deg, #fff4d9 0%, #ffe7ad 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 30rpx rgba(255, 185, 64, 0.16);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  color: #7a4b00;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: #8b5a00;
  line-height: 1.6;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.hero-tag {
  display: block;
  width: 48%;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #8b5a00;
  padding: 0;
  margin-bottom: 12rpx;
  text-align: left;
  line-height: 1.4;
  align-self: flex-start;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.card-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.input {
  display: block;
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

.primary-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #f8d377 0%, #f1b94a 100%);
  color: #7a4b00;
  text-align: center;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 88rpx;
  height: 88rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 185, 64, 0.18);
}

.action-group {
  display: block;
  margin-top: 24rpx;
}

.action-btn {
  display: block;
  width: 100%;
  margin: 0;
  padding: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.action-btn::after {
  border: none;
}

.action-btn-secondary {
  background: #fff8e8;
  color: #8b5a00;
  border: 1rpx solid #f0d28b;
  box-sizing: border-box;
}

.benefit-item {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.benefit-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
