.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.type-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.type-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.type-arrow {
  font-size: 28rpx;
  color: #666;
}

.input-wrap {
  margin-bottom: 20rpx;
}

.input {
  display: block;
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

.option-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.del-icon {
  width: 48rpx;
  height: 48rpx;
  background: #ff4444;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 16rpx 0;
}

.add-option {
  display: block;
  font-size: 30rpx;
  color: #333;
  padding: 24rpx 0;
}

.hint {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.required-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.required-text {
  font-size: 32rpx;
  color: #333;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background: white;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
}

.btn-cancel {
  flex: 1;
  background: white;
  border: 1rpx solid #ddd;
  color: #666;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-save {
  flex: 1;
  background: #1989fa;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}
