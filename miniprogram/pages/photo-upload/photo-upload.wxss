/* 页面容器 */
.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.card-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.spec-info {
  display: flex;
  font-size: 28rpx;
}

.spec-label {
  color: #999;
  min-width: 160rpx;
}

.spec-value {
  color: #333;
  flex: 1;
}

/* 章节 */
.section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 照片预览 */
.preview {
  width: 100%;
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.photo {
  width: 100%;
  height: 100%;
}

.empty-preview {
  width: 100%;
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 按钮 */
.choose-btn {
  background: #1989fa;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
}

/* 自定义字段 */
.field-item {
  margin-bottom: 24rpx;
}

.field-item:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4444;
  margin-left: 4rpx;
}

/* 输入框 */
.input {
  display: block;
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

/* 选择器 */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-text {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.picker-arrow {
  font-size: 48rpx;
  color: #999;
  transform: rotate(90deg);
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
}

.submit-btn {
  background: #07c160;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #999;
}
