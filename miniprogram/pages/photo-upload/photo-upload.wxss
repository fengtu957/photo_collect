.container {
  padding: 20rpx;
}

.preview {
  width: 100%;
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 100%;
}

.choose-btn {
  background: #1989fa;
  color: white;
  margin-bottom: 20rpx;
}

.submit-btn {
  background: #07c160;
  color: white;
}

.submit-btn[disabled] {
  background: #ccc;
}
