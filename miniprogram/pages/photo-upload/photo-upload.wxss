/* 页面容器 */
.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.card-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.spec-info {
  display: flex;
  font-size: 28rpx;
}

.spec-label {
  color: #999;
  min-width: 160rpx;
}

.spec-value {
  color: #333;
  flex: 1;
}

.task-status {
  margin-top: 16rpx;
}

.task-status-text {
  font-size: 26rpx;
  color: #ff9500;
}

.photo-size-tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #fff7e6;
  border: 1rpx solid #ffe2b3;
}

.photo-size-tip-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #b86a00;
  word-break: break-all;
  overflow-wrap: break-word;
}

.analysis-panel {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e8e8;
  background: #fff;
}

.analysis-panel-existing {
  background: #f7f8fa;
  border-color: #e5e7eb;
}

.analysis-panel-loading {
  background: #f4f9ff;
  border-color: #cfe4ff;
}

.analysis-panel-pass {
  background: #f3fbf6;
  border-color: #b7e7c7;
}

.analysis-panel-fail,
.analysis-panel-error {
  background: #fff7f7;
  border-color: #f3c7c7;
}

.analysis-panel-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.analysis-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
  font-weight: bold;
}

.analysis-badge-loading {
  background: #d9ecff;
  color: #0f6ecf;
}

.analysis-badge-pass {
  background: #dff5e6;
  color: #0d8f4d;
}

.analysis-badge-fail {
  background: #ffe1e1;
  color: #d33a3a;
}

.analysis-headline {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.analysis-note {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  word-break: break-all;
  overflow-wrap: break-word;
}

.analysis-summary {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.analysis-summary-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.8);
  border: 1rpx solid rgba(0,0,0,0.04);
  text-align: center;
  box-sizing: border-box;
}

.analysis-summary-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.analysis-summary-value {
  display: block;
  font-size: 30rpx;
  color: #222;
  font-weight: bold;
  word-break: break-all;
}

.analysis-breakdown {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.analysis-breakdown-item {
  width: calc(33.333% - 8rpx);
  box-sizing: border-box;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.92);
  padding: 16rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.analysis-breakdown-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.analysis-breakdown-value {
  display: block;
  font-size: 28rpx;
  color: #222;
  font-weight: bold;
}

.analysis-list {
  width: 100%;
  box-sizing: border-box;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.analysis-list + .analysis-list {
  margin-top: 12rpx;
}

.analysis-list-title {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.analysis-list-item {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  word-break: break-all;
  overflow-wrap: break-word;
}

.analysis-actions {
  margin-top: 16rpx;
}

.analysis-action-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  margin: 0;
  border-radius: 10rpx;
  background: #1989fa;
  color: #fff;
  font-size: 28rpx;
}

/* 章节 */
.section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 照片预览 */
.preview {
  width: 100%;
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.photo {
  width: 100%;
  height: 100%;
}

.empty-preview {
  width: 100%;
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 按钮 */
.choose-btn {
  background: #1989fa;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
}

.choose-btn[disabled] {
  background: #ccc;
  color: #999;
}

/* 自定义字段 */
.field-item {
  margin-bottom: 24rpx;
}

.field-item:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4444;
  margin-left: 4rpx;
}

/* 输入框 */
.input {
  display: block;
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

/* 选择器 */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-text {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.picker-arrow {
  font-size: 48rpx;
  color: #999;
  transform: rotate(90deg);
}

.multiselect-group {
  width: 100%;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
  box-sizing: border-box;
  background: #fff;
}

.multiselect-option {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.multiselect-option:last-child {
  border-bottom: none;
}

.multiselect-text {
  margin-left: 16rpx;
  font-size: 30rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 底部按钮 */
.footer-placeholder {
  height: 128rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  z-index: 100;
}

.submit-btn {
  background: #07c160;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #999;
}
