<view class="page">
  <!-- 任务信息 -->
  <view class="card" wx:if="{{task}}">
    <view class="card-title">{{task.title}}</view>
    <view class="card-desc" wx:if="{{task.description}}">{{task.description}}</view>
    <view class="spec-info">
      <text class="spec-label">照片规格：</text>
      <text class="spec-value">{{task.photo_spec.name}} ({{task.photo_spec.width}}×{{task.photo_spec.height}})</text>
    </view>
    <view class="spec-info" wx:if="{{task.photo_spec.background_color}}">
      <text class="spec-label">背景色要求：</text>
      <text class="spec-value">{{task.photo_spec.background_color}}</text>
    </view>
    <view class="spec-info" wx:if="{{task.photo_spec.max_size_kb > 0}}">
      <text class="spec-label">大小限制：</text>
      <text class="spec-value">{{task.photo_spec.max_size_kb}}K，超出会自动压缩</text>
    </view>
    <view class="task-status" wx:if="{{taskStatusText}}">
      <text class="task-status-text">{{taskStatusText}}</text>
    </view>
  </view>

  <!-- 照片预览 -->
  <view class="section">
    <view class="section-title">上传照片</view>
    <view class="preview" wx:if="{{photoPath}}">
      <image class="photo" src="{{photoPath}}" mode="aspectFit" />
    </view>
    <view class="empty-preview" wx:else>
      <text class="empty-text">请选择照片</text>
    </view>
    <button class="choose-btn" bindtap="choosePhoto" disabled="{{!!taskUnavailableMessage}}">
      {{photoPath ? '重新选择' : '选择照片'}}
    </button>
    <view class="photo-size-tip" wx:if="{{task && task.photo_spec && task.photo_spec.max_size_kb > 0}}">
      <text class="photo-size-tip-text">当前任务限制 {{task.photo_spec.max_size_kb}}K，超出后会自动压缩，仍超出则无法提交。</text>
    </view>
    <view class="photo-size-tip" wx:if="{{!aiAnalysisEnabled}}">
      <text class="photo-size-tip-text">当前任务未开启 AI 分析，选择照片并填写信息后可直接提交。</text>
    </view>

    <view class="analysis-panel analysis-panel-existing" wx:if="{{aiAnalysisEnabled && analysisState === 'existing' && analysisMessage}}">
      <text class="analysis-note">{{analysisMessage}}</text>
    </view>

    <view class="analysis-panel analysis-panel-loading" wx:if="{{aiAnalysisEnabled && analysisState === 'analyzing'}}">
      <view class="analysis-panel-head">
        <text class="analysis-badge analysis-badge-loading">检查中</text>
        <text class="analysis-headline">AI 正在检查这张照片</text>
      </view>
      <text class="analysis-note">{{analysisMessage}}</text>
    </view>

    <view class="analysis-panel analysis-panel-error" wx:if="{{aiAnalysisEnabled && analysisState === 'error'}}">
      <view class="analysis-panel-head">
        <text class="analysis-badge analysis-badge-fail">检查失败</text>
        <text class="analysis-headline">当前无法完成 AI 检查</text>
      </view>
      <text class="analysis-note">{{analysisError}}</text>
      <view class="analysis-actions">
        <button class="analysis-action-btn" bindtap="retryAnalyzePhoto">重新检测</button>
      </view>
    </view>

    <view class="analysis-panel {{analysisPassed ? 'analysis-panel-pass' : 'analysis-panel-fail'}}" wx:if="{{aiAnalysisEnabled && analysisState === 'success' && analysisResult}}">
      <view class="analysis-panel-head">
        <text class="analysis-badge {{analysisPassed ? 'analysis-badge-pass' : 'analysis-badge-fail'}}">{{analysisPassed ? '可提交' : '需重拍'}}</text>
        <text class="analysis-headline">{{analysisMessage}}</text>
      </view>

      <view class="analysis-summary">
        <view class="analysis-summary-item">
          <text class="analysis-summary-label">AI总分</text>
          <text class="analysis-summary-value">{{analysisResult.score}}</text>
        </view>
        <view class="analysis-summary-item">
          <text class="analysis-summary-label">识别人数</text>
          <text class="analysis-summary-value">{{analysisResult.person_count}}</text>
        </view>
        <view class="analysis-summary-item">
          <text class="analysis-summary-label">人脸识别</text>
          <text class="analysis-summary-value">{{analysisResult.face_detected ? '已检测到' : '未检测到'}}</text>
        </view>
      </view>

      <view class="analysis-breakdown">
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">清晰度</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.clarity || 0}}</text>
        </view>
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">光线</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.lighting || 0}}</text>
        </view>
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">角度</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.angle || 0}}</text>
        </view>
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">背景</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.background || 0}}</text>
        </view>
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">表情</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.expression || 0}}</text>
        </view>
        <view class="analysis-breakdown-item">
          <text class="analysis-breakdown-label">构图</text>
          <text class="analysis-breakdown-value">{{analysisResult.breakdown.composition || 0}}</text>
        </view>
      </view>

      <view class="analysis-list" wx:if="{{analysisResult.issues && analysisResult.issues.length > 0}}">
        <text class="analysis-list-title">主要问题</text>
        <text class="analysis-list-item" wx:for="{{analysisResult.issues}}" wx:key="*this" wx:for-item="issue">{{issue}}</text>
      </view>

      <view class="analysis-list" wx:if="{{analysisResult.suggestions && analysisResult.suggestions.length > 0}}">
        <text class="analysis-list-title">调整建议</text>
        <text class="analysis-list-item" wx:for="{{analysisResult.suggestions}}" wx:key="*this" wx:for-item="suggestion">{{suggestion}}</text>
      </view>
    </view>
  </view>

  <!-- 自定义字段 -->
  <view class="section" wx:if="{{task && task.custom_fields && task.custom_fields.length > 0}}">
    <view class="section-title">填写信息</view>
    <view class="card">
      <view class="field-item" wx:for="{{task.custom_fields}}" wx:key="id">
        <view class="field-label">
          <text>{{item.label}}</text>
          <text class="required" wx:if="{{item.required}}">*</text>
        </view>

        <!-- 文本输入 -->
        <input
          wx:if="{{item.type === 'text'}}"
          class="input"
          placeholder="{{item.placeholder || '请输入' + item.label}}"
          value="{{customData[item.id]}}"
          data-field="{{item.id}}"
          bindinput="onCustomFieldInput"
          adjust-position="{{false}}"
        />

        <!-- 数字输入 -->
        <input
          wx:if="{{item.type === 'number'}}"
          class="input"
          type="number"
          placeholder="{{item.placeholder || '请输入' + item.label}}"
          value="{{customData[item.id]}}"
          data-field="{{item.id}}"
          bindinput="onCustomFieldInput"
          adjust-position="{{false}}"
        />

        <!-- 单选 -->
        <picker
          wx:if="{{item.type === 'select'}}"
          mode="selector"
          range="{{item.options}}"
          data-field="{{item.id}}"
          bindchange="onCustomFieldChange"
        >
          <view class="picker">
            <text class="picker-text">{{customData[item.id] || '请选择' + item.label}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>

        <!-- 多选 -->
        <view wx:if="{{item.type === 'multiselect'}}" class="multiselect-group">
          <checkbox-group data-field="{{item.id}}" bindchange="onMultiSelectChange">
            <label class="multiselect-option" wx:for="{{item.options}}" wx:key="*this" wx:for-item="option">
              <checkbox
                value="{{option}}"
                checked="{{multiSelectState[item.id] && multiSelectState[item.id][option]}}"
                color="#1989fa"
              />
              <text class="multiselect-text">{{option}}</text>
            </label>
          </checkbox-group>
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="footer-placeholder"></view>
  <view class="footer">
    <button class="submit-btn" bindtap="submitPhoto" disabled="{{!photoPath || !!taskUnavailableMessage || !canSubmit || (aiAnalysisEnabled && analysisState === 'analyzing')}}">
      {{taskUnavailableMessage ? '当前不可提交' : ((aiAnalysisEnabled && analysisState === 'analyzing') ? 'AI检查中...' : (isEditMode ? '更新' : '提交'))}}
    </button>
  </view>
</view>
