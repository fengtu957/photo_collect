<view class="page">
  <view class="list">
    <view class="item" wx:for="{{fields}}" wx:key="id">
      <view class="item-content">
        <view class="del-icon" catchtap="removeField" data-index="{{index}}">−</view>
        <text class="item-text" bindtap="editField" data-index="{{index}}">{{item.label}}</text>
        <view class="sort-btns">
          <text class="sort-btn" catchtap="moveUp" data-index="{{index}}" wx:if="{{index > 0}}">↑</text>
          <text class="sort-btn" catchtap="moveDown" data-index="{{index}}" wx:if="{{index < fields.length - 1}}">↓</text>
        </view>
        <text class="arrow" bindtap="editField" data-index="{{index}}">›</text>
      </view>
    </view>
  </view>

  <view class="add-area" bindtap="addField">
    <view class="add-icon">+</view>
    <text class="add-text">自定义采集信息</text>
    <text class="arrow">›</text>
  </view>

  <view class="tip">自定义采集信息，是拍照活动的参与者在提交照片给管理员时需要填写的信息；可以设置 1-5 条自定义采集信息。</view>
</view>
