.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.list {
  background: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.area {
  width: 100%;
}

.item {
  width: 100%;
  min-height: 120rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-content {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.del-icon {
  width: 48rpx;
  height: 48rpx;
  background: #ff4444;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-tags {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.item-tag {
  font-size: 22rpx;
  line-height: 1;
  color: #1989fa;
  background: rgba(25, 137, 250, 0.12);
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  margin-right: 10rpx;
}

.item-tag-unique {
  color: #ff9500;
  background: rgba(255, 149, 0, 0.14);
}

.add-area {
  background: white;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  background: #07c160;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.add-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.sort-btns {
  display: flex;
  flex-direction: column;
  margin-right: 12rpx;
}

.sort-btn {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
  line-height: 1.4;
}

.tip {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  padding: 0 10rpx;
}
