<scroll-view scroll-y style="height: 100vh;">
  <view class="form">
    <view class="section">
      <text class="label">任务标题 *</text>
      <input class="input" placeholder="请输入任务标题" bindinput="onInput" data-field="title" value="{{form.title}}" adjust-position="{{false}}" />
    </view>

    <view class="section">
      <text class="label">任务描述</text>
      <textarea class="textarea" placeholder="请输入任务描述" bindinput="onInput" data-field="description" value="{{form.description}}" adjust-position="{{false}}" />
    </view>

    <view class="section">
      <view class="switch-row">
        <view class="switch-copy">
          <text class="label switch-label">开启AI分析</text>
          <text class="switch-tip">关闭后上传照片不做 AI 检查，也不会生成 AI 评分。</text>
        </view>
        <switch checked="{{form.ai_analysis_enabled}}" bindchange="onAIAnalysisChange" color="#1989fa" />
      </view>
    </view>

    <view class="section">
      <view class="row-link spec-entry" bindtap="goToPhotoSpecSelect">
        <text class="label">照片规格 *</text>
        <view class="spec-entry-content">
          <text class="spec-summary" wx:if="{{form.photo_spec.name}}">
            {{form.photo_spec.name}} {{form.photo_spec.width}}×{{form.photo_spec.height}}mm{{form.photo_spec.background_color ? '，' + form.photo_spec.background_color : ''}}
          </text>
          <text class="spec-placeholder" wx:else>请选择规格</text>
          <text class="spec-entry-arrow">›</text>
        </view>
      </view>
      <view class="row">
        <view class="row-item">
          <text class="sub-label">大小限制(K)</text>
          <input class="input" type="number" placeholder="0表示不限制" bindinput="onSpecInput" data-field="max_size_kb" value="{{maxSizeKBInput}}" adjust-position="{{false}}" />
        </view>
      </view>
    </view>

    <view class="section">
      <text class="label">开始时间</text>
      <view class="time-row">
        <picker mode="date" bindchange="onStartDateChange" class="time-picker">
          <view class="picker">{{startDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" bindchange="onStartTimeChange" class="time-picker">
          <view class="picker">{{startTime || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <view class="section">
      <text class="label">截止时间 *</text>
      <view class="time-row">
        <picker mode="date" bindchange="onEndDateChange" class="time-picker">
          <view class="picker">{{endDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" bindchange="onEndTimeChange" class="time-picker">
          <view class="picker">{{endTime || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <view class="section" bindtap="goToCustomFields">
      <view class="row-link">
        <text class="label">自定义采集信息</text>
        <text class="link-meta">{{form.custom_fields.length > 0 ? form.custom_fields.length + '项' : '未设置'}} ›</text>
      </view>
    </view>

    <button class="submit-btn" bindtap="onSubmit">{{isEditMode ? '保存修改' : '创建任务'}}</button>
  </view>
</scroll-view>
