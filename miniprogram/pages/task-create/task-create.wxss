.form {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.vip-notice {
  background: linear-gradient(135deg, #fff8e7 0%, #fff2cc 100%);
  border-color: #f3e2a8;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.vip-tip {
  display: block;
  font-size: 24rpx;
  color: #8b5a00;
  line-height: 1.6;
}

.vip-link {
  font-size: 28rpx;
  color: #b2760f;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.sub-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.switch-copy {
  flex: 1;
  min-width: 0;
}

.switch-label {
  margin-bottom: 8rpx;
}

.switch-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.input {
  display: block;
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

.textarea {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  height: 160rpx;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.textarea::placeholder {
  color: #999;
}

.row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.row-item {
  flex: 1;
}

.picker {
  font-size: 28rpx;
  color: #999;
  border-bottom: 1rpx solid #eee;
  padding: 12rpx 0;
}

.time-row {
  display: flex;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
}

.row-link {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.link-meta {
  font-size: 28rpx;
  color: #999;
}

.row-link .label {
  margin-bottom: 0;
}

.spec-entry {
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 16rpx;
}

.spec-entry-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
}

.spec-summary {
  font-size: 24rpx;
  color: #1989fa;
  max-width: 420rpx;
  text-align: right;
  word-break: break-all;
  overflow-wrap: break-word;
}

.spec-placeholder {
  font-size: 24rpx;
  color: #999;
}

.spec-entry-arrow {
  font-size: 36rpx;
  color: #bbb;
  line-height: 1;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.submit-btn {
  background: #1989fa;
  color: white;
  border-radius: 60rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
}
