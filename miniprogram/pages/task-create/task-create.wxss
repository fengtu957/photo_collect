.form {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.sub-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

.input::placeholder {
  color: #999;
}

.textarea {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  height: 160rpx;
  border: none;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.textarea::placeholder {
  color: #999;
}

.row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.row-item {
  flex: 1;
}

.picker {
  font-size: 28rpx;
  color: #999;
  border-bottom: 1rpx solid #eee;
  padding: 12rpx 0;
}

.time-row {
  display: flex;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
}

.row-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.link-meta {
  font-size: 28rpx;
  color: #999;
}

.submit-btn {
  background: #1989fa;
  color: white;
  border-radius: 60rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
}
